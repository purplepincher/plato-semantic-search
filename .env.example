# plato-semantic-search configuration
#
# Copy to `.env` (gitignored) if you source env vars locally. This file only
# covers values consumed by this repo's tooling (the seed script). For full
# deploy instructions see SETUP.md.
#
# The Worker itself has NO API tokens to set: `AI` and `VECTORIZE` are
# Cloudflare *bindings* (declared in wrangler.toml, provisioned by your
# account), and the only Worker secret is the optional `API_KEY`, which must be
# set via `wrangler secret put API_KEY` (production) or in `.dev.vars` (local).

# Base URL of a deployed/local Worker, used by `npm run seed` / live e2e tests.
PLATO_BASE_URL=https://plato-semantic-search.your-account.workers.dev

# Optional Bearer token protecting the Worker's endpoints.
# Used by scripts/seed.ts (defaults to the API_KEY env var) and by the live
# e2e test (PLATO_E2E_API_KEY). Generate with: openssl rand -hex 32
# API_KEY=

# Live end-to-end test target (test/e2e.test.ts). When unset, the live block is
# skipped so CI runs without cloud credentials.
# PLATO_E2E_URL=https://plato-semantic-search.your-account.workers.dev
# PLATO_E2E_API_KEY=
