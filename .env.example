# Plato Semantic Search Configuration

# Cloudflare Worker Environment Variables
PLATO_VECTORIZE_INDEX=plato-semantic-index
PLATO_WORKER_URL=https://plato-semantic-search.your-account.workers.dev

# API Secrets
INGEST_SECRET=your-super-secret-ingest-key
WEBHOOK_SECRET=your-super-secret-webhook-key

# Queue Configuration
PLATO_SYNC_QUEUE_NAME=plato-sync-queue

# Local Development
WRANGLER_ENV=development
